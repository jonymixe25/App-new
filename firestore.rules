rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - role: string (required, 'admin' or 'user')
    //   - email: string (required)
    //
    // Collection: news
    // Document ID: {newsId}
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - author: string (required)
    //   - date: string (required)
    //   - imageUrl: string (optional)
    //   - videoUrl: string (optional)
    //
    // Collection: community_videos
    // Document ID: {videoId}
    // Fields:
    //   - title: string (required)
    //   - author: string (required)
    //   - thumbnail: string (required)
    //   - price: string (required)
    //   - video_url: string (required)
    //
    // Collection: team
    // Document ID: {memberId}
    // Fields:
    //   - name: string (required)
    //   - role: string (required)
    //   - bio: string (required)
    //   - image: string (required)
    //   - icon: string (required)
    //   - linkedin: string (optional)
    //   - twitter: string (optional)
    //   - github: string (optional)
    //   - email: string (optional)
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "mixecultura25@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.role in ['admin', 'user'] && data.email is string;
    }

    function isValidNews(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.date is string &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() < 1000));
    }

    function isValidCommunityVideo(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.thumbnail is string && data.thumbnail.size() > 0 && data.thumbnail.size() < 1000 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.video_url is string && data.video_url.size() > 0 && data.video_url.size() < 1000;
    }

    function isValidTeamMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.bio is string && data.bio.size() < 2000 &&
             data.image is string && data.image.size() < 1000 &&
             data.icon is string && data.icon.size() < 50 &&
             (!('linkedin' in data) || (data.linkedin is string && data.linkedin.size() < 1000)) &&
             (!('twitter' in data) || (data.twitter is string && data.twitter.size() < 1000)) &&
             (!('github' in data) || (data.github is string && data.github.size() < 1000)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 100));
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if false;
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidNews(request.resource.data);
      allow delete: if isAdmin();
    }

    match /community_videos/{videoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCommunityVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /team/{memberId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTeamMember(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
