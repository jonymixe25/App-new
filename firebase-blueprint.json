{
  "entities": {
    "TeamMember": {
      "title": "Team Member",
      "description": "A member of the Vida Mixe TV team.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the member"
        },
        "role": {
          "type": "string",
          "description": "Role in the team (e.g., Director, Editor, Presenter)"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email"
        },
        "bio": {
          "type": "string",
          "description": "Short biography"
        },
        "photoUrl": {
          "type": "string",
          "format": "uri",
          "description": "Profile picture URL"
        },
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID if applicable"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the member was added"
        }
      },
      "required": ["name", "role", "email"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of team members"
    }
  }
}
